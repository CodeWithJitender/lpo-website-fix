{
  "presets": [
    "@babel/preset-env",
    "@babel/preset-react"
  ],
  "plugins": [
    [
      "module-resolver", {
        "root": ["./src"],
				"alias": {
					"@": "./src"
				}
      }
    ],
		[
			"babel-plugin-import",
			{
				"libraryName": "@mui/material",
				"libraryDirectory": "",
				"camel2DashComponentName": false
			},
			"core"
		],
		[
			"babel-plugin-import",
			{
				"libraryName": "@mui/icons-material",
				"libraryDirectory": "",
				"camel2DashComponentName": false
			},
			"icons"
		],
		"@loadable/babel-plugin"
  ]
}

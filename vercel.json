{
  "version": 2,
	"buildCommand": "npm run build",
	"installCommand": "npm ci",
	"outputDirectory": "build",
  "builds": [
    {
      "src": "build/public/server.js",
      "use": "@vercel/node",
			"config": {
        "includeFiles": ["build/assets-manifest.json"]
      }
    },
		{
			"src": "build/public/**",
			"use": "@vercel/static"
		}
  ],
  "routes": [
		{
			"src": "/assets/(.+)",
			"dest": "build/public/$1",
			"headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
		},
		{
			"src": "/robots.txt",
			"dest": "build/public/robots.txt"
		},
    {
      "src": "/(.*)",
      "dest": "build/public/server.js",
			"headers": {
				"X-Content-Type-Options": "nosniff",
				"X-Frame-Options": "DENY",
				"X-XSS-Protection": "1; mode=block"
			}
    }
  ]
}

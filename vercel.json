{
  "version": 2,
  "builds": [
    {
      "src": "build/public/server.js",
      "use": "@vercel/node"
    },
		{
				"src": "build/public/**",
				"use": "@vercel/static"
		}
  ],
  "routes": [
		{
				"src": "/assets/(.+)",
				"dest": "build/public/$1"
		},
    {
      "src": "/(.*)",
      "dest": "build/public/server.js"
    }
  ]
}
